# ──────────────────────────────────────────────────────────────────────────────
#  Cheikh Distribution — Backend Production Environment
#  Copier ce fichier en .env et remplir toutes les valeurs manquantes.
# ──────────────────────────────────────────────────────────────────────────────

# App
NODE_ENV=production
PORT=5000
CLIENT_URL=https://www.cheikhdistribution.sn
BACKEND_URL=https://api.cheikhdistribution.sn

# MongoDB Atlas
MONGO_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/cheikh-distribution?appName=Cluster0
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/cheikh-distribution?appName=Cluster0

# JWT
# Générer un secret fort : node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=<secret-aleatoire-64-octets-minimum>
JWT_EXPIRE=30d

# Cloudflare Turnstile (dashboard.cloudflare.com → Turnstile)
TURNSTILE_SECRET_KEY=<votre-cle-secrete-turnstile>

# Google OAuth (console.cloud.google.com)
GOOGLE_CLIENT_ID=<votre-google-client-id>

# Email SMTP Gmail (activer "Mot de passe d'application" dans les paramètres Google)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=noreplycheikhdistribution@gmail.com
EMAIL_PASS=<mot-de-passe-application-16-caracteres>

# Upload
MAX_FILE_SIZE=5242880
UPLOAD_PATH=./uploads/

# ── Paiements ──────────────────────────────────────────────────────────────────

# Wave (wave.com/business → API)
WAVE_API_KEY=<votre-wave-api-key>
WAVE_API_SECRET=<votre-wave-api-secret>
WAVE_API_URL=https://api.wave.com/v1
WAVE_MERCHANT_ID=<votre-wave-merchant-id>

# Orange Money
ORANGE_MONEY_MERCHANT_KEY=<votre-orange-money-merchant-key>
ORANGE_MONEY_AUTH_URL=https://api.orange.com/oauth/v2/token
ORANGE_MONEY_PAYMENT_URL=https://api.orange.com/orange-money-webpay/prod/v1/webpayment

# Stripe (si applicable)
STRIPE_SECRET_KEY=<votre-stripe-secret-key>
STRIPE_WEBHOOK_SECRET=<votre-stripe-webhook-secret>
