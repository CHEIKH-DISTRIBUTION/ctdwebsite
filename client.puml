@startuml
|Client|
start
:Parcourir catalogue;
:Ajouter produit au panier;
:Valider panier;
if (Connecté ?) then (non)
  :S'identifier / s'inscrire;
endif
:Choisir adresse de livraison;
:Sélectionner méthode de paiement (Wave/Orange Money);
:Initier paiement;
if (Paiement réussi ?) then (oui)
  :Voir confirmation de commande;
  :Recevoir notification (SMS / Email);
else (non)
  :Afficher erreur de paiement;
  stop
endif
|Livreur|
:Recevoir mission de livraison;
:Consulter détails + itinéraire;
:Mettre à jour statut -> "En cours de livraison";
if (Livraison réussie ?) then (oui)
  :Marquer "Livré";
  ->|Client| :Client voit statut mis à jour;
  :Recevoir notification de livraison;
else (non)
  :Marquer "Échec";
  ->|Client| :Client est notifié du problème;
endif
|Admin / Gestionnaire stock|
:Surveiller niveaux de stock;
if (Stock bas ?) then (oui)
  :Recevoir alerte;
  :Réapprovisionner / bloquer produit;
  :Mettre à jour visibilité produit;
endif
stop
@enduml
