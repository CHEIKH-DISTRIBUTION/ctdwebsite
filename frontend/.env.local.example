# Copy this file to .env.local and fill in the values.
# NEXT_PUBLIC_ variables are exposed to the browser bundle.

# Backend API base URL (no trailing slash)
NEXT_PUBLIC_API_URL=http://localhost:5000

# Cloudflare Turnstile site key — https://dash.cloudflare.com → Turnstile
# Leave empty in dev: the widget auto-bypasses when this is unset
NEXT_PUBLIC_TURNSTILE_SITE_KEY=

# Google OAuth client ID — https://console.cloud.google.com
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# Facebook App ID — https://developers.facebook.com
NEXT_PUBLIC_FACEBOOK_APP_ID=
