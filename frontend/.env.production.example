# ──────────────────────────────────────────────────────────────────────────────
#  Cheikh Distribution — Frontend Production Environment
#  Copier ce fichier en .env.production.local et remplir toutes les valeurs.
#  (Next.js charge .env.production.local en priorité pour les builds de prod.)
# ──────────────────────────────────────────────────────────────────────────────

# URL de l'API backend (sans slash final)
NEXT_PUBLIC_API_URL=https://api.cheikhdistribution.sn

# Cloudflare Turnstile — clé publique (dashboard.cloudflare.com → Turnstile)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=<votre-site-key-turnstile>

# Google OAuth — client ID (console.cloud.google.com)
NEXT_PUBLIC_GOOGLE_CLIENT_ID=<votre-google-client-id>
